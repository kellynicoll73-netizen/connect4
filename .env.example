# Apt — required environment variables
# Copy this file to .env.local and fill in your own keys.
# .env.local is gitignored and should never be committed.

# Card version for A/B testing (A, B, or C)
NEXT_PUBLIC_CARD_VERSION=C

# Voyage AI — semantic neighbourhood matching
# Sign up at https://dash.voyageai.com
# IMPORTANT: You must add a payment method in the Voyage dashboard to unlock
# standard rate limits. The free tier (200M tokens) still applies after adding
# a card — you will not be charged unless you exceed the free allowance.
# Without a payment method, API calls are limited to 3 requests/minute and
# will fail under normal quiz usage.
VOYAGE_API_KEY=

# Anthropic — Claude-generated personalised comparison text
# Sign up at https://console.anthropic.com
# IMPORTANT: This feature requires Anthropic credits on your account.
# The cost per quiz completion is very small (a few cents at most),
# but a funded account is required for the personalisation feature to activate.
# The app falls back to static comparison text if this key is absent or the call fails.
ANTHROPIC_API_KEY=
